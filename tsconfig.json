{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "types": ["node", "mocha"]
  },
  "include": ["lib/**/*", "bin/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "data"]
}
