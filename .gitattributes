# GitHub Linguist 语言检测覆盖
# https://github.com/github-linguist/linguist/blob/master/docs/overrides.md

# 类型声明文件明确标记为 TypeScript
*.d.ts linguist-language=TypeScript

# bin shim 文件标记为 generated，不计入语言统计
bin/fip-cli.js linguist-generated=true

# 构建脚本标记为 generated
scripts/build-org-cache.js linguist-generated=true

# 配置文件标记为 generated
eslint.config.js linguist-generated=true
